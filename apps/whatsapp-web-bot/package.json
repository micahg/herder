{
  "name": "@herder/whatsapp-web-bot",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "set -a; [ -f .env ] && . ./.env; set +a; NODE_OPTIONS='--inspect=9229' tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "set -a; [ -f .env ] && . ./.env; set +a; tsx src/index.ts",
    "check": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.3",
    "hono": "^4.7.5",
    "qrcode-terminal": "^0.12.0",
    "whatsapp-web.js": "^1.31.0"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/qrcode-terminal": "^0.12.2",
    "tsx": "^4.20.5",
    "typescript": "^5.8.2",
    "vitest": "^4.1.0"
  }
}
