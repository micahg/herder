# Server
PORT=3000

# Required setup secret for one-time pairing and QR retrieval
WA_WEB_ADMIN_SETUP_TOKEN=replace-with-long-random-token

# Optional whatsapp-web.js LocalAuth client id
WA_WEB_CLIENT_ID=herder

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/auto
OPENROUTER_SYSTEM_PROMPT=You are a concise, friendly assistant replying to WhatsApp users. Keep answers practical and brief unless they ask for detail.
OPENROUTER_SITE_URL=https://herder.local
OPENROUTER_APP_TITLE=Herder

# Optional command prefix used to trigger bot replies
BOT_MENTION_PREFIX=!herder
