{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "herder",
  "main": "src/index.ts",
  "compatibility_date": "2026-03-16",
  "vars": {
    "OPENROUTER_MODEL": "openrouter/auto",
    "OPENROUTER_APP_TITLE": "Herder",
    "OPENROUTER_SITE_URL": "https://herder.local"
  },
  "observability": {
    "enabled": true
  }
}